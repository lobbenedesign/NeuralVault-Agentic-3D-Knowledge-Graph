{
  "manifest_version": 3,
  "name": "Aura Bridge | NeuralVault",
  "version": "1.0",
  "description": "Cattura istantaneamente conoscenza dal web nel tuo NeuralVault locale.",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": ["http://localhost:8001/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
