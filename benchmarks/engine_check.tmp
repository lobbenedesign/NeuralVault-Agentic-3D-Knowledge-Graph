# ─────────────────────────────────────────────
# Phase 9: Industrialization (The Planner)
# ─────────────────────────────────────────────

class QueryIntent:
    SEMANTIC = "semantic"   # Ricerca per somiglianza (HNSW)
    ANALYTIC = "analytic"   # Ricerca su metadati (DuckDB)
    RELATIONAL = "relational" # Ricerca tra connessioni (Graph)
    HYBRID = "hybrid"      # Default

class NeuralQueryPlanner:
    """Il 'Cervello' che decide come interrogare la memoria."""
    def plan(self, query: str) -> str:
        q_lower = query.lower()
        if any(w in q_lower for w in ["mostra", "quanti", "data", "filtra", "dove"]):
            return QueryIntent.ANALYTIC
        if any(w in q_lower for w in ["legato a", "connessione", "perché", "relazione"]):
            return QueryIntent.RELATIONAL
        return QueryIntent.HYBRID

# ─────────────────────────────────────────────
# NeuralVault Engine Core (v0.2.5 Consolidated)
# ─────────────────────────────────────────────

class NeuralVaultEngine:
    """
    Sovereign Multimodal Memory Engine.
    Orchestra HNSW, Grafi Semantici, TurboQuant e Persistence Layer.
    """
    def __init__(
        self,
        dim:              int = 1024,
        data_dir:         str | None = None,
        use_quantization: bool = True,
        use_rust:         bool = False,
        embedder_fn:      Callable = None,
        collection:       str = "default",
    ):
        self.dim                = dim
        self.data_dir           = Path(data_dir) if data_dir else None
        self.default_collection = collection
        self._embedder_fn       = embedder_fn
        self._query_planner     = NeuralQueryPlanner()

        # 1. Storage & Memory Tiers (Consolidated)
        self._tiers    = MemoryTierManager(data_dir=self.data_dir)
        self._nodes    = {}
        self._sessions = SessionManager(data_dir=self.data_dir)

        # 2. Vector Index (HNSW)
        self._hnsw = AdaptiveHNSW(dim=dim, use_rust=use_rust)
        
        # 3. Metadata Index (DuckDB)
        self._prefilter = DuckDBPrefilter(db_path=self.data_dir)
        
        # 4. Sparse & Fusion
        self._sparse = BM25SEncoder()
        self._ranker = FusionRanker()
        
        # 5. Graph Layer
        self._graph_ingester = AutoKnowledgeLinker()
        self._graph          = None # Lazy load
        
        # 6. TurboQuant Search (Innovation Fase 8)
        self._tq_search = None
        if use_quantization:
            self._tq_search = TwoStageTurboSearch(dim=dim, use_rust=use_rust)
            
        # 7. Recovery (se data_dir esiste)
        if self.data_dir:
            self._load_state()

    def _load_state(self):
        """Ripristina lo stato persistente."""
        if not self.data_dir: return
        try:
            # Caricamento nodi... 
            pass
        except Exception as e:
            print(f"⚠️ Errore caricamento: {e}")

    # ─────────────────────────────────────────
    # Ingestion
    # ─────────────────────────────────────────

    def upsert(self, node: VaultNode):
        """Inserisce o aggiorna un nodo (Ingestion Pipeline v0.2.5)."""
        self._nodes[node.id] = node
        if node.vector is not None:
            self._hnsw.insert(node)
            if self._tq_search:
                self._tq_search.add(node.id, node.vector)
        
        # 1. Tier Routing (Working -> Episodic)
        self._tiers.put(node, tier=MemoryTier.WORKING)
        
        # 2. Analytical Indexing (DuckDB)
        self._prefilter.add_node(node.id, self.default_collection, node.metadata)
        
        # 3. Graph Analysis
        self._graph_ingester.link_batch([node] + list(self._nodes.values())[:10])
        self._graph = None # Invalidate graph cache

    def upsert_text(self, text: str, metadata: dict | None = None, id: str | None = None) -> VaultNode:
        """Entry point rapido per l'agente (Text-to-Vault)."""
        vector = self._embed_text(text)
        node = VaultNode(id=id or str(uuid.uuid4()), text=text, vector=vector, metadata=metadata or {})
        self.upsert(node)
        return node

    # ─────────────────────────────────────────
    # Query Orchestration
    # ─────────────────────────────────────────

    def query(
        self,
        query_text:             str,
        query_vector:           Optional[np.ndarray] = None,
        k:                      int   = 10,
        ef:                     int   = 50,
        metadata_filter:        Optional[dict | str] = None,
        alpha:                  float = 0.7,
        session_id:             Optional[str] = None,
        use_progressive:        bool  = True,
        intent:                 str   = None,
    ) -> list[QueryResult]:
        """
        Query intelligente con Orchestrazione del NeuralQueryPlanner.
        """
        start_time = time.time()
        
        if not intent:
            intent = self._query_planner.plan(query_text)
        print(f"🧠 Query Planner Intent: {intent}")

        if query_vector is None:
            query_vector = self._embed_text(query_text)

        allowed_ids = None
        if isinstance(metadata_filter, str) and self._prefilter:
            allowed_ids = set(self._prefilter.filter(metadata_filter))

        # 1. Dense Search
        dense_results = []
        if query_vector is not None:
            if self._tq_search and not use_progressive:
                dense_results_raw = self._tq_search.search(query_vector, k=k*3, filter_ids=allowed_ids)
                dense_results = [(nid, d) for nid, d in dense_results_raw]
            else:
                dense_results = self._hnsw.search(query_vector, k=k*2, ef=ef)

        # 2. Graph Bonus (se intent relazionale)
        graph_results = []
        if intent == QueryIntent.RELATIONAL:
            graph = self._get_graph()
            graph_results = graph.traverse(query_vector, max_hops=1)

        # 3. Fusion & Speculative Reranking
        results = self._ranker.fuse(
            dense_results=dense_results,
            sparse_results=[], 
            graph_results=graph_results,  
            nodes=self._nodes,
            query_text=query_text,
            top_k=k,
            rerank_n=50
        )

        duration = (time.time() - start_time) * 1000
        print(f"✅ NeuralVault: Query {intent} completata in {duration:.2f}ms")
        return results

    def feedback(self, node_id: str, success: bool = True):
        """Learning Loop attivo."""
        if node_id not in self._nodes: return
        node = self._nodes[node_id]
        if self._tq_search and node.vector is not None:
            impact = 0.1 if success else -0.05
            self._tq_search.quantizer.update_daba_resolutions(np.abs(node.vector) * impact)
            
    # ─────────────────────────────────────────
    # Helpers
    # ─────────────────────────────────────────

    def _embed_text(self, text: str) -> np.ndarray:
        if self._embedder_fn is not None:
            raw = self._embedder_fn(text)
            return np.array(raw, dtype=np.float32)
        return np.random.randn(self.dim).astype(np.float32)

    def _get_graph(self) -> ContextGraph:
        if self._graph is None:
            self._graph = ContextGraph(list(self._nodes.values()))
        return self._graph

    def _save_state(self):
        if self.data_dir:
            pass

    def close(self):
        """Chiusura procedurale di tutti i tier di memoria (Industrial v0.2.5)."""
        print("📦 NeuralVault: Committing all memories to disk...")
        if self._prefilter:
            self._prefilter.close()
        if self._tiers:
            self._tiers.close()
        print("✅ NeuralVault: Sovereign Engine offline.")
